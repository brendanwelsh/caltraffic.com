---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import Header from '../../components/astro/Header.astro';
import Footer from '../../components/astro/Footer.astro';
import { CameraPageContent } from '../../components/react/CameraPageContent';

const { id } = Astro.params;

// Parse camera ID to get district (D03-1 or D03-001)
const districtMatch = id?.match(/^D(\d{2})-/);
const districtNum = districtMatch ? parseInt(districtMatch[1], 10) : null;

const title = `Camera ${id} — Cal Traffic`;
const description = `Live traffic camera view — Cal Traffic`;
---

<Base title={title} description={description}>
  <div class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1 px-4 py-6 md:px-6">
      {districtNum && id ? (
        <CameraPageContent cameraId={id} district={districtNum} client:load />
      ) : (
        <div class="flex flex-col items-center justify-center py-20 text-center">
          <h1 class="text-2xl font-bold mb-2">Invalid Camera ID</h1>
          <p class="text-muted-foreground mb-4">Camera ID format should be like D03-1</p>
          <a href="/cameras" class="rounded-lg border border-input px-4 py-2 text-sm hover:bg-accent transition-colors">
            Browse cameras
          </a>
        </div>
      )}
    </main>
    <Footer />
  </div>
</Base>
