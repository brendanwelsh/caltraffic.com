---
export const prerender = false;

import Base from '../layouts/Base.astro';
import Header from '../components/astro/Header.astro';
import Footer from '../components/astro/Footer.astro';
import { TrafficReports } from '../components/react/TrafficReports';
---

<Base title="Traffic Reports — Cal Traffic">
  <div class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1 px-4 py-8 md:px-6 max-w-5xl mx-auto w-full">
      <TrafficReports client:load />
    </main>
    <Footer />
  </div>
</Base>
