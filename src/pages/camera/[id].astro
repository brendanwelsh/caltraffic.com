---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import Header from '../../components/astro/Header.astro';
import Footer from '../../components/astro/Footer.astro';

const { id } = Astro.params;

// Parse camera ID to get district
// Format: D03-123
const districtMatch = id?.match(/^D(\d{2})-/);
const districtNum = districtMatch ? parseInt(districtMatch[1], 10) : null;

let camera: any = null;
let error: string | null = null;

if (districtNum && id) {
  try {
    // Fetch directly from CWWP2 (can't self-reference on Cloudflare Workers)
    const { buildCwwp2Url } = await import('../../lib/constants');
    const url = buildCwwp2Url('cctv', districtNum);
    const response = await fetch(url);
    if (response.ok) {
      const rawData = await response.json() as any;
      const items = rawData?.data ?? (Array.isArray(rawData) ? rawData : []);
      const { extractRoute, extractRouteNumber, extractDirection, extractPostmile, parseInService, cleanLocationName } = await import('../../lib/utils');
      const { getRouteType, formatRoute, PHOTO_ONLY_DISTRICTS } = await import('../../lib/constants');

      for (let idx = 0; idx < items.length; idx++) {
        const item = items[idx];
        const cctv = item?.cctv ?? item;
        const loc = cctv?.location ?? {};
        // Match the ID format from the API: D03-1, D03-2, etc.
        const camId = `D${String(districtNum).padStart(2, '0')}-${idx + 1}`;
        // Also try the URL format which might be D03-001
        const urlId = id;
        if (camId === urlId || camId === urlId?.replace(/-0+/, '-')) {
          const routeNum = extractRouteNumber(loc.route);
          camera = {
            id: urlId!,
            district: districtNum,
            route: formatRoute(routeNum),
            routeType: getRouteType(routeNum),
            direction: extractDirection(loc.direction),
            county: String(loc.county ?? ''),
            city: String(loc.nearbyPlace ?? ''),
            location: cleanLocationName(String(loc.locationName ?? '')),
            latitude: parseFloat(String(loc.latitude ?? '0')),
            longitude: parseFloat(String(loc.longitude ?? '0')),
            postmile: extractPostmile(loc.postmile),
            imageUrl: cctv?.imageData?.static?.currentImageURL ?? '',
            streamUrl: cctv?.imageData?.streamingVideoURL ?? null,
            hasVideo: !PHOTO_ONLY_DISTRICTS.has(districtNum) && !!cctv?.imageData?.streamingVideoURL,
            inService: parseInService(cctv?.inService),
            isStale: false,
          };
          break;
        }
      }
      if (!camera) error = 'Camera not found in district data';
    } else {
      error = 'Failed to fetch camera data from Caltrans';
    }
  } catch (e) {
    error = `Failed to load camera: ${e}`;
  }
}

const title = camera
  ? `${camera.route} ${camera.direction} at ${camera.location || camera.city} — Cal Traffic`
  : 'Camera — Cal Traffic';

const description = camera
  ? `Live traffic camera on ${camera.route} ${camera.direction} near ${camera.city}, ${camera.county}. District ${camera.district}.`
  : 'California traffic camera view.';

const ogImage = camera?.imageUrl ?? '';
---

<Base title={title} description={description} ogImage={ogImage || undefined}>
  <div class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1 px-4 py-6 md:px-6">
      {error || !camera ? (
        <div class="flex flex-col items-center justify-center py-20 text-center">
          <h1 class="text-2xl font-bold mb-2">Camera Not Found</h1>
          <p class="text-muted-foreground mb-4">{error || 'The requested camera could not be found.'}</p>
          <a href="/" class="rounded-lg border border-input px-4 py-2 text-sm hover:bg-accent transition-colors">
            Back to all cameras
          </a>
        </div>
      ) : (
        <div class="max-w-3xl mx-auto">
          <div class="mb-4">
            <a href="/" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
              &larr; Back to cameras
            </a>
          </div>

          <div class="rounded-xl border border-border bg-card overflow-hidden">
            <img
              src={camera.imageUrl}
              alt={`Traffic camera: ${camera.location}`}
              class="w-full"
            />
            <div class="p-4">
              <div class="flex items-center gap-2 mb-2">
                <img
                  src={`https://shields.caltranscameras.app/${camera.route}.svg`}
                  alt={camera.route}
                  class="h-6"
                />
                <h1 class="text-xl font-semibold">{camera.location || camera.city}</h1>
              </div>
              <p class="text-sm text-muted-foreground">
                {camera.route} {camera.direction} &mdash; {camera.city}, {camera.county} &mdash; District {camera.district}
              </p>

              <div class="mt-4 flex flex-wrap gap-2">
                <span class:list={[
                  'inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-medium',
                  camera.hasVideo ? 'bg-green-500/10 text-green-500' : 'bg-gray-500/10 text-gray-400'
                ]}>
                  {camera.hasVideo ? 'Live Video' : 'Static Image'}
                </span>
                {camera.isStale && (
                  <span class="inline-flex items-center rounded-full bg-yellow-500/10 px-2.5 py-1 text-xs font-medium text-yellow-500">
                    Feed may be delayed
                  </span>
                )}
              </div>

              <div class="mt-4 grid grid-cols-2 gap-3 text-sm">
                <div><span class="text-muted-foreground">Postmile:</span> {camera.postmile?.toFixed(1)}</div>
                <div><span class="text-muted-foreground">Coordinates:</span> {camera.latitude?.toFixed(4)}, {camera.longitude?.toFixed(4)}</div>
              </div>

              <div class="mt-4 flex gap-2">
                <a
                  href={`https://www.google.com/maps?q=${camera.latitude},${camera.longitude}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 rounded-lg border border-input px-3 py-1.5 text-sm hover:bg-accent transition-colors"
                >
                  Open in Google Maps
                </a>
              </div>
            </div>
          </div>
        </div>
      )}
    </main>
    <Footer />
  </div>
</Base>
