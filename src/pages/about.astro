---
export const prerender = false;

import Base from '../layouts/Base.astro';
import Header from '../components/astro/Header.astro';
import Footer from '../components/astro/Footer.astro';
---

<Base title="About — Cal Traffic">
  <div class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1 px-4 py-8 md:px-6 max-w-4xl mx-auto w-full">

      <h1 class="text-3xl font-bold mb-4">About Cal Traffic</h1>
      <p class="text-muted-foreground text-lg mb-6">
        A real-time traffic camera viewer and route planner for California highways. Plan your route, see cameras along it, and check road conditions — all in one place, ad-free.
      </p>

      <!-- Data Sources -->
      <h2 class="text-2xl font-semibold mb-3">Data Sources</h2>
      <p class="text-sm text-muted-foreground mb-3">All data is public domain, sourced from California state agencies and open services.</p>
      <div class="overflow-x-auto mb-10">
        <table class="w-full text-sm border border-border rounded-lg">
          <thead>
            <tr class="border-b border-border bg-muted/50">
              <th class="px-3 py-2 text-left font-medium">Source</th>
              <th class="px-3 py-2 text-left font-medium">Provides</th>
              <th class="px-3 py-2 text-left font-medium">Refresh</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-border"><td class="px-3 py-2"><a href="https://cwwp2.dot.ca.gov/" class="text-foreground underline hover:text-primary" target="_blank" rel="noopener">Caltrans CWWP2</a></td><td class="px-3 py-2 text-muted-foreground">3,000+ cameras, CMS signs, chain controls, lane closures, RWIS weather, travel times</td><td class="px-3 py-2 text-muted-foreground">30-120s</td></tr>
            <tr class="border-b border-border"><td class="px-3 py-2"><a href="https://media.chp.ca.gov/sa_xml/sa.xml" class="text-foreground underline hover:text-primary" target="_blank" rel="noopener">CHP Incidents</a></td><td class="px-3 py-2 text-muted-foreground">Real-time traffic incidents statewide</td><td class="px-3 py-2 text-muted-foreground">60s</td></tr>
            <tr class="border-b border-border"><td class="px-3 py-2"><a href="https://api.weather.gov/" class="text-foreground underline hover:text-primary" target="_blank" rel="noopener">National Weather Service</a></td><td class="px-3 py-2 text-muted-foreground">Active weather alerts for California</td><td class="px-3 py-2 text-muted-foreground">5 min</td></tr>
            <tr class="border-b border-border"><td class="px-3 py-2"><a href="https://router.project-osrm.org/" class="text-foreground underline hover:text-primary" target="_blank" rel="noopener">OSRM</a></td><td class="px-3 py-2 text-muted-foreground">Route geometry and turn-by-turn directions</td><td class="px-3 py-2 text-muted-foreground">On demand</td></tr>
            <tr><td class="px-3 py-2 text-foreground">Photon / Nominatim</td><td class="px-3 py-2 text-muted-foreground">Address and city geocoding</td><td class="px-3 py-2 text-muted-foreground">On demand</td></tr>
          </tbody>
        </table>
      </div>

      <!-- District Map -->
      <h2 class="text-2xl font-semibold mb-4">Caltrans District Map</h2>
      <div class="mb-4">
        <img
          src="https://cwwp2.dot.ca.gov/documentation/district-map-edited-2019.png"
          alt="Map of the 12 Caltrans districts covering California, showing district boundaries and headquarters cities"
          class="rounded-lg border border-border max-w-md mx-auto w-full"
          loading="lazy"
        />
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-1 text-sm text-muted-foreground mb-10">
        <p><strong class="text-foreground">D01</strong> — Eureka / North Coast</p>
        <p><strong class="text-foreground">D02</strong> — Redding / Northeastern CA</p>
        <p><strong class="text-foreground">D03</strong> — Sacramento / North Central</p>
        <p><strong class="text-foreground">D04</strong> — Oakland / Bay Area</p>
        <p><strong class="text-foreground">D05</strong> — San Luis Obispo / Central Coast</p>
        <p><strong class="text-foreground">D06</strong> — Fresno / Central Valley South</p>
        <p><strong class="text-foreground">D07</strong> — Los Angeles / LA Metro</p>
        <p><strong class="text-foreground">D08</strong> — San Bernardino / Inland Empire</p>
        <p><strong class="text-foreground">D09</strong> — Bishop / Eastern Sierra</p>
        <p><strong class="text-foreground">D10</strong> — Stockton / Central Valley North</p>
        <p><strong class="text-foreground">D11</strong> — San Diego / Border Region</p>
        <p><strong class="text-foreground">D12</strong> — Irvine / Orange County</p>
      </div>

      <!-- District Capability Matrix -->
      <h2 class="text-2xl font-semibold mb-4">District Capability Matrix</h2>
      <p class="text-muted-foreground mb-4">
        Not all data sources are available in every district. This is a Caltrans limitation, not an app limitation.
      </p>
      <div class="overflow-x-auto mb-10">
        <table class="w-full text-sm border border-border rounded-lg">
          <thead>
            <tr class="border-b border-border bg-muted/50">
              <th class="px-3 py-2 text-left font-medium">District</th>
              <th class="px-3 py-2 text-center font-medium">Cameras</th>
              <th class="px-3 py-2 text-center font-medium">Signs</th>
              <th class="px-3 py-2 text-center font-medium">Chains</th>
              <th class="px-3 py-2 text-center font-medium">Closures</th>
              <th class="px-3 py-2 text-center font-medium">Weather</th>
              <th class="px-3 py-2 text-center font-medium">Travel</th>
              <th class="px-3 py-2 text-center font-medium">Live Video</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-border"><td class="px-3 py-2">D01 — Eureka</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-muted-foreground">-</td><td class="px-3 py-2 text-center text-muted-foreground">-</td><td class="px-3 py-2 text-center text-green-500">Y</td></tr>
            <tr class="border-b border-border"><td class="px-3 py-2">D02 — Redding</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-muted-foreground">-</td><td class="px-3 py-2 text-center text-green-500">Y</td></tr>
            <tr class="border-b border-border"><td class="px-3 py-2">D03 — Sacramento</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td></tr>
            <tr class="border-b border-border"><td class="px-3 py-2">D04 — Bay Area</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-muted-foreground">-</td><td class="px-3 py-2 text-center text-muted-foreground">-</td><td class="px-3 py-2 text-center text-green-500">Y</td></tr>
            <tr class="border-b border-border"><td class="px-3 py-2">D05 — SLO</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-muted-foreground">-</td><td class="px-3 py-2 text-center text-muted-foreground">-</td><td class="px-3 py-2 text-center text-green-500">Y</td></tr>
            <tr class="border-b border-border"><td class="px-3 py-2">D06 — Fresno</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-muted-foreground">-</td><td class="px-3 py-2 text-center text-green-500">Y</td></tr>
            <tr class="border-b border-border"><td class="px-3 py-2">D07 — Los Angeles</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-muted-foreground">-</td><td class="px-3 py-2 text-center text-muted-foreground">-</td><td class="px-3 py-2 text-center text-amber-500">Photo</td></tr>
            <tr class="border-b border-border"><td class="px-3 py-2">D08 — Inland Empire</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-amber-500">Photo</td></tr>
            <tr class="border-b border-border"><td class="px-3 py-2">D09 — Bishop</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-muted-foreground">-</td><td class="px-3 py-2 text-center text-amber-500">Photo</td></tr>
            <tr class="border-b border-border"><td class="px-3 py-2">D10 — Stockton</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-muted-foreground">-</td><td class="px-3 py-2 text-center text-amber-500">Photo</td></tr>
            <tr class="border-b border-border"><td class="px-3 py-2">D11 — San Diego</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-muted-foreground">-</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-amber-500">Photo</td></tr>
            <tr><td class="px-3 py-2">D12 — Orange County</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-muted-foreground">-</td><td class="px-3 py-2 text-center text-green-500">Y</td><td class="px-3 py-2 text-center text-amber-500">Photo</td></tr>
          </tbody>
        </table>
      </div>

      <!-- How the cameras work -->
      <h2 class="text-2xl font-semibold mb-3">How the Cameras Work</h2>
      <p class="text-sm text-muted-foreground mb-4">
        Camera feeds come from the <a href="https://cwwp2.dot.ca.gov/" class="text-foreground underline hover:text-primary" target="_blank" rel="noopener">Caltrans Commercial Wholesale Web Portal (CWWP2)</a>, which aggregates traffic cameras from all 12 Caltrans districts.
      </p>
      <div class="space-y-3 text-sm mb-6">
        <div class="rounded-lg border border-border bg-card p-3">
          <p class="font-medium mb-1">Still images vs. live video</p>
          <p class="text-muted-foreground">Most cameras provide static snapshots that update every 1–5 minutes depending on the district. Approximately 1,800 cameras also support real-time video streams — these are shown with a live video badge and play directly in the viewer.</p>
        </div>
        <div class="rounded-lg border border-border bg-card p-3">
          <p class="font-medium mb-1">What "Stale" means</p>
          <p class="text-muted-foreground">A camera is marked <strong>stale</strong> when its image hasn't updated in 15 or more minutes. This usually means the camera is offline, under maintenance, or experiencing a network issue on Caltrans's end. It is not an app error.</p>
        </div>
        <div class="rounded-lg border border-border bg-card p-3">
          <p class="font-medium mb-1">Camera quality</p>
          <p class="text-muted-foreground">Camera quality varies widely across the state. Newer installations are HD (1080p or better); many older units are low-resolution NTSC cameras from the early 2000s. Caltrans is gradually upgrading the fleet but the rollout is ongoing.</p>
        </div>
      </div>

      <!-- Chain Control levels -->
      <h2 class="text-2xl font-semibold mb-3">Chain Control Levels</h2>
      <p class="text-sm text-muted-foreground mb-4">
        Chain controls are issued by Caltrans field crews for mountain passes and winter routes. The three levels indicate increasing severity:
      </p>
      <div class="space-y-2 text-sm mb-10">
        <div class="flex gap-3 rounded-lg border border-border bg-card p-3 items-start">
          <span class="font-bold text-yellow-400 w-6 flex-shrink-0">R1</span>
          <p class="text-muted-foreground">Chains or snow tires required on drive wheels. Vehicles with all-wheel drive and adequate tread may be exempt depending on conditions.</p>
        </div>
        <div class="flex gap-3 rounded-lg border border-border bg-card p-3 items-start">
          <span class="font-bold text-orange-400 w-6 flex-shrink-0">R2</span>
          <p class="text-muted-foreground">Chains required on all vehicles, no exceptions. Snow tires and AWD are not sufficient — physical chains must be installed on drive wheels.</p>
        </div>
        <div class="flex gap-3 rounded-lg border border-border bg-card p-3 items-start">
          <span class="font-bold text-red-400 w-6 flex-shrink-0">R3</span>
          <p class="text-muted-foreground">Highway closed to all traffic. The road is impassable and no vehicles are permitted through, including commercial trucks and emergency-equipped vehicles.</p>
        </div>
      </div>

      <!-- Data freshness -->
      <h2 class="text-2xl font-semibold mb-3">Data Freshness</h2>
      <p class="text-sm text-muted-foreground mb-4">
        All data is public and freely available from California state agencies and federal services. Here's how often each source updates:
      </p>
      <div class="overflow-x-auto mb-10">
        <table class="w-full text-sm border border-border rounded-lg">
          <thead>
            <tr class="border-b border-border bg-muted/50">
              <th class="px-3 py-2 text-left font-medium">Data Type</th>
              <th class="px-3 py-2 text-left font-medium">Source</th>
              <th class="px-3 py-2 text-left font-medium">Update Frequency</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-border">
              <td class="px-3 py-2 font-medium">Camera stills</td>
              <td class="px-3 py-2 text-muted-foreground">Caltrans CWWP2</td>
              <td class="px-3 py-2 text-muted-foreground">Near real-time (1–5 min lag)</td>
            </tr>
            <tr class="border-b border-border">
              <td class="px-3 py-2 font-medium">Live video</td>
              <td class="px-3 py-2 text-muted-foreground">Caltrans CWWP2</td>
              <td class="px-3 py-2 text-muted-foreground">Real-time stream</td>
            </tr>
            <tr class="border-b border-border">
              <td class="px-3 py-2 font-medium">Incident reports</td>
              <td class="px-3 py-2 text-muted-foreground">CHP CAD system</td>
              <td class="px-3 py-2 text-muted-foreground">Updated as dispatchers log events (~60s)</td>
            </tr>
            <tr class="border-b border-border">
              <td class="px-3 py-2 font-medium">Chain controls</td>
              <td class="px-3 py-2 text-muted-foreground">Caltrans field crews</td>
              <td class="px-3 py-2 text-muted-foreground">Updated manually as conditions change</td>
            </tr>
            <tr class="border-b border-border">
              <td class="px-3 py-2 font-medium">Lane closures</td>
              <td class="px-3 py-2 text-muted-foreground">Caltrans CWWP2</td>
              <td class="px-3 py-2 text-muted-foreground">Updated as work zones open/close</td>
            </tr>
            <tr>
              <td class="px-3 py-2 font-medium">Weather alerts</td>
              <td class="px-3 py-2 text-muted-foreground">National Weather Service API</td>
              <td class="px-3 py-2 text-muted-foreground">Updated as conditions change (~5 min)</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Support -->
      <h2 class="text-2xl font-semibold mb-4">Support This Project</h2>
      <p class="text-muted-foreground mb-6">
        If you find this tool useful, consider supporting its development. Every bit helps keep the servers running and the data flowing.
      </p>
      <div class="flex flex-wrap gap-3 mb-10">
        <a
          href="https://buymeacoffee.com/brendanwelsh"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-lg bg-[#FFDD00] px-5 py-2.5 text-sm font-semibold text-[#000000] hover:bg-[#FFDD00]/90 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" x2="6" y1="2" y2="4"/><line x1="10" x2="10" y1="2" y2="4"/><line x1="14" x2="14" y1="2" y2="4"/></svg>
          Buy Me a Coffee
        </a>
        <a
          href="https://paypal.me/BrendanWelsh"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-lg border border-[#0070BA]/40 bg-[#0070BA]/10 px-5 py-2.5 text-sm font-semibold text-[#0070BA] hover:bg-[#0070BA]/20 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 11A4.5 4.5 0 0 1 11.5 7h1A4.5 4.5 0 0 1 17 11.5a4 4 0 0 1-4 3.5H9.5L8 21H4l3-10Z"/><path d="M15 7a4.5 4.5 0 0 1 4 4.5 4 4 0 0 1-4 3.5h-1"/></svg>
          PayPal
        </a>
      </div>

    </main>
    <Footer />
  </div>
</Base>
